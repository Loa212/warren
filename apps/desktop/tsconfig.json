{
  "extends": "@warren/config/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["bun-types"],
    "skipLibCheck": true,
    "paths": {
      "electrobun": ["./types/electrobun.d.ts"],
      "electrobun/bun": ["./types/electrobun.d.ts"],
      "@warren/types": ["../../packages/types/src/index.ts"],
      "@warren/core": ["../../packages/core/src/index.ts"],
      "@warren/themes": ["../../packages/themes/src/index.ts"]
    }
  },
  "include": ["src", "electrobun.config.ts", "types"],
  "exclude": ["../../node_modules", "node_modules"]
}
