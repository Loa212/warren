{
  "name": "warren",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=@warren/desktop --filter=@warren/web --filter=@warren/docs",
    "dev:web": "turbo dev --filter=@warren/core --filter=@warren/web",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/qrcode": "^1.5.6",
    "turbo": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "qrcode": "^1.5.4"
  }
}
